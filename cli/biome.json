{
	"$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"files": {
		"include": ["**"],
		"ignore": ["dist", "node_modules"]
	}
}
